{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Orders"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "user_id": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    },
    "total_amount": {
      "type": "integer"
    },
    "order_status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "paid",
        "shipped",
        "cancelled"
      ]
    }
  }
}
